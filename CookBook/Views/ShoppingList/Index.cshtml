@model IReadOnlyList<CookBook.Dtos.ShoppingListSummaryDto>
@{
    ViewData["Title"] = "Listy zakupów";
}

<partial name="_PageHeader" model="@("Listy zakupów")" />

<div class="mx-auto max-w-3xl px-4">

    <form asp-action="Create" method="post" class="mb-6 flex gap-2 rounded-lg border border-gray-200 bg-white p-4 shadow-sm">
        <input name="name" placeholder="Nazwa listy (np. Zakupy na weekend)" class="flex-1 rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" />
        <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700">+ Nowa lista</button>
    </form>

    @if (!Model.Any())
    {
        <div class="rounded-lg border border-dashed border-gray-300 bg-white p-10 text-center text-gray-400">
            Nie masz jeszcze żadnej listy zakupów.
        </div>
    }
    else
    {
        <div class="space-y-2">
            @foreach (var list in Model)
            {
                <a asp-action="Details" asp-route-id="@list.Id" class="flex items-center justify-between rounded-lg border border-gray-200 bg-white px-4 py-3 shadow-sm transition hover:shadow-md">
                    <div>
                        <div class="font-semibold text-gray-800">@list.Name</div>
                        <div class="text-xs text-gray-500">@list.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")</div>
                    </div>
                    <span class="text-sm text-gray-500">@list.CheckedCount / @list.ItemCount odhaczone</span>
                </a>
            }
        </div>
    }
</div>
