@using CookBook.ViewModels
@model CookBook.Dtos.RecipeDetailsDto
@{
    ViewData["Title"] = Model.Name;
    var canEdit = ViewBag.CanEdit == true;
    var shoppingLists = ViewBag.ShoppingLists as List<LookupItem> ?? new List<LookupItem>();

    var currentUserIdClaim = Context.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var currentUserId = currentUserIdClaim != null ? (int?)int.Parse(currentUserIdClaim) : null;
    // Zgłosić może każdy zalogowany, kto nie jest autorem (także moderator).
    var canReportRecipe = currentUserId != null && currentUserId != Model.OwnerId;
}

<div class="mx-auto max-w-3xl px-4 py-6">
    <div class="mb-4 flex items-start justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">@Model.Name</h1>
            <p class="mt-1 text-sm text-gray-500">
                @Model.AuthorName • @Model.DifficultyName • @Model.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")
            </p>
        </div>
        <div class="flex gap-2">
            @* Przycisk pobierania PDF dostępny dla każdego *@
            <a asp-action="DownloadPdf" asp-route-id="@Model.Id" class="rounded-lg bg-green-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-green-700">📄 Pobierz PDF</a>
            
            @if (canEdit)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="rounded-lg border border-gray-300 px-3 py-1.5 text-sm text-gray-700 hover:bg-gray-50">Edytuj</a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="rounded-lg border border-red-300 px-3 py-1.5 text-sm text-red-600 hover:bg-red-50">Usuń</a>
            }
        </div>
    </div>

    @* Zgłoszenie przepisu — dla każdego zalogowanego, kto nie jest autorem *@
    @if (canReportRecipe)
    {
        <div class="mb-4">
            <button type="button" onclick="document.getElementById('report-recipe-form').classList.toggle('hidden')"
                    class="text-xs text-gray-400 hover:text-red-600 focus:outline-none">⚠️ Zgłoś przepis</button>
            <div id="report-recipe-form" class="mt-2 hidden">
                <form asp-controller="Report" asp-action="ReportRecipe" method="post" class="space-y-2 rounded-lg border border-red-100 bg-red-50 p-3">
                    <input type="hidden" name="recipeId" value="@Model.Id" />
                    <label class="block text-xs font-semibold text-gray-600">Powód zgłoszenia</label>
                    <textarea name="reason" rows="2" maxlength="1000" required
                              class="w-full rounded-lg border border-gray-300 p-2 text-sm focus:border-red-500 focus:outline-none focus:ring-1 focus:ring-red-500"
                              placeholder="Opisz, co jest nie tak z tym przepisem..."></textarea>
                    <div class="flex justify-end gap-2">
                        <button type="button" onclick="document.getElementById('report-recipe-form').classList.add('hidden')"
                                class="rounded px-3 py-1 text-xs text-gray-500 hover:text-gray-700">Anuluj</button>
                        <button type="submit" class="rounded bg-red-600 px-3 py-1 text-xs font-medium text-white hover:bg-red-700">Wyślij zgłoszenie</button>
                    </div>
                </form>
            </div>
        </div>
    }

    @if (Model.ImageUrls.Any())
    {
        <div class="mb-6 grid grid-cols-2 gap-2 sm:grid-cols-3">
            @foreach (var url in Model.ImageUrls)
            {
                <img src="@url" alt="@Model.Name" class="h-40 w-full rounded-lg object-cover" />
            }
        </div>
    }

    <div class="mb-4 flex flex-wrap gap-2">
        @foreach (var cat in Model.Categories)
        {
            <span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-medium text-indigo-700">@cat</span>
        }
        @foreach (var tag in Model.Tags)
        {
            <span class="rounded-full bg-gray-100 px-3 py-1 text-xs text-gray-600">#@tag</span>
        }
    </div>

    <div class="mb-6 flex flex-wrap gap-6 text-sm text-gray-600">
        @if (Model.PrepTimeMinutes.HasValue) { <span>⏱️ Przygotowanie: @Model.PrepTimeMinutes min</span> }
        @if (Model.CookTimeMinutes.HasValue) { <span>🔥 Gotowanie: @Model.CookTimeMinutes min</span> }
        @if (Model.Servings.HasValue) { <span>🍽️ Porcje: @Model.Servings</span> }
        @if (Model.AverageRating.HasValue) { <span class="text-amber-500">★ @Model.AverageRating.Value.ToString("0.0") (@Model.ReviewCount)</span> }
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Description))
    {
        <p class="mb-6 text-gray-700">@Model.Description</p>
    }

    <div class="grid gap-6 md:grid-cols-3">
        <div class="md:col-span-1">
            <h2 class="mb-2 text-lg font-bold text-gray-800">Składniki</h2>
            <ul class="space-y-1 text-sm text-gray-700">
                @foreach (var ing in Model.Ingredients)
                {
                    <li class="flex justify-between border-b border-gray-100 py-1">
                        <span>@ing.IngredientName</span>
                        <span class="text-gray-500">@ing.Amount.ToString("0.##") @ing.UnitName</span>
                    </li>
                }
            </ul>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <form asp-controller="ShoppingList" asp-action="AddRecipe" method="post" class="mt-4 space-y-2 rounded-lg border border-indigo-100 bg-indigo-50 p-3">
                    <input type="hidden" name="recipeId" value="@Model.Id" />
                    <label class="block text-xs font-semibold text-gray-600">Dodaj składniki do listy zakupów</label>
                    @if (shoppingLists.Any())
                    {
                        <select name="listId" id="sl-select" class="w-full rounded-lg border border-gray-300 px-2 py-1.5 text-sm">
                            @foreach (var l in shoppingLists)
                            {
                                <option value="@l.Id">@l.Name</option>
                            }
                            <option value="0">— nowa lista —</option>
                        </select>
                        <input name="newListName" id="sl-newname" placeholder="Nazwa nowej listy" class="hidden w-full rounded-lg border border-gray-300 px-2 py-1.5 text-sm" />
                    }
                    else
                    {
                        <input name="newListName" placeholder="Nazwa nowej listy" class="w-full rounded-lg border border-gray-300 px-2 py-1.5 text-sm" />
                    }
                    <button type="submit" class="w-full rounded-lg bg-indigo-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-indigo-700">🛒 Dodaj do listy</button>
                </form>

                @if (shoppingLists.Any())
                {
                    <script>
                        (function () {
                            const select = document.getElementById('sl-select');
                            const nameInput = document.getElementById('sl-newname');
                            function toggle() {
                                nameInput.classList.toggle('hidden', select.value !== '0');
                            }
                            select.addEventListener('change', toggle);
                            toggle();
                        })();
                    </script>
                }
            }
        </div>

        <div class="md:col-span-2">
            <h2 class="mb-2 text-lg font-bold text-gray-800">Przygotowanie</h2>
            <ol class="space-y-3">
                @foreach (var step in Model.Steps)
                {
                    <li class="flex gap-3">
                        <span class="flex h-7 w-7 flex-none items-center justify-center rounded-full bg-indigo-600 text-sm font-semibold text-white">@step.Order</span>
                        <p class="pt-0.5 text-sm text-gray-700">@step.Content</p>
                    </li>
                }
            </ol>
        </div>
    </div>

    <div class="mt-12 border-t border-gray-200 pt-8">
        
        @* Formularz Oceny *@
        @if (Context.User.Identity?.IsAuthenticated == true)
        {
            <div class="mb-8 rounded-lg border border-indigo-50 bg-indigo-50 p-6">
                <h3 class="mb-3 font-bold text-gray-800">Twoja ocena</h3>
                <form asp-controller="Recipe" asp-action="AddReview" method="post" class="flex items-center gap-4">
                    <input type="hidden" name="recipeId" value="@Model.Id" />
                    
                    <select name="rating" class="rounded-lg border border-indigo-200 p-2 text-sm focus:border-indigo-500 focus:outline-none">
                        <option value="5">⭐⭐⭐⭐⭐ (5)</option>
                        <option value="4">⭐⭐⭐⭐ (4)</option>
                        <option value="3">⭐⭐⭐ (3)</option>
                        <option value="2">⭐⭐ (2)</option>
                        <option value="1">⭐ (1)</option>
                    </select>
                    
                    <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700">Oceń przepis</button>
                </form>
            </div>
        }

        <h2 class="mb-6 text-xl font-bold text-gray-800">Komentarze (@Model.Comments.Count)</h2>

        @if (Context.User.Identity?.IsAuthenticated == true)
        {
            <form asp-controller="Recipe" asp-action="AddComment" method="post" class="mb-8">
                <input type="hidden" name="recipeId" value="@Model.Id" />
                <div class="mb-2">
                    <textarea name="content" rows="3" class="w-full rounded-lg border border-gray-300 p-3 text-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="Napisz co myślisz o tym przepisie..." required></textarea>
                </div>
                <div class="flex justify-end">
                    <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700">Dodaj komentarz</button>
                </div>
            </form>
        }
        else
        {
            <div class="mb-8 rounded-lg bg-gray-50 p-4 text-center text-sm text-gray-600">
                Aby dodać komentarz musisz się <a href="/Identity/Account/Login" class="font-medium text-indigo-600 hover:underline">zalogować</a>.
            </div>
        }

        @{
            var commentVd = new ViewDataDictionary(ViewData);
            commentVd["RecipeId"] = Model.Id;
            commentVd["IsAuthenticated"] = Context.User.Identity?.IsAuthenticated == true;
            var currentUserIdStr = Context.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            commentVd["CurrentUserId"] = currentUserIdStr != null ? (int?)int.Parse(currentUserIdStr) : null;
            commentVd["IsModerator"] = Context.User.IsInRole("Moderator");
        }
        <div class="space-y-6">
            @foreach (var comment in Model.Comments)
            {
                @await Html.PartialAsync("_Comment", comment, commentVd)
            }

            @if (!Model.Comments.Any())
            {
                <p class="text-center text-sm text-gray-500">Brak komentarzy. Bądź pierwszą osobą, która oceni ten przepis!</p>
            }
        </div>
    </div>

    <div class="mt-8">
        <a asp-action="Index" class="text-sm text-indigo-600 hover:underline">← Wróć do listy</a>
    </div>
</div>