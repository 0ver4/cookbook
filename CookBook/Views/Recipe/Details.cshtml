@using CookBook.ViewModels
@model CookBook.Dtos.RecipeDetailsDto
@{
    ViewData["Title"] = Model.Name;
    var canEdit = ViewBag.CanEdit == true;
    var shoppingLists = ViewBag.ShoppingLists as List<LookupItem> ?? new List<LookupItem>();
}

<div class="mx-auto max-w-3xl px-4 py-6">
    <div class="mb-4 flex items-start justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">@Model.Name</h1>
            <p class="mt-1 text-sm text-gray-500">
                @Model.AuthorName • @Model.DifficultyName • @Model.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")
            </p>
        </div>
        @if (canEdit)
        {
            <div class="flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="rounded-lg border border-gray-300 px-3 py-1.5 text-sm text-gray-700 hover:bg-gray-50">Edytuj</a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="rounded-lg border border-red-300 px-3 py-1.5 text-sm text-red-600 hover:bg-red-50">Usuń</a>
            </div>
        }
    </div>

    @if (Model.ImageUrls.Any())
    {
        <div class="mb-6 grid grid-cols-2 gap-2 sm:grid-cols-3">
            @foreach (var url in Model.ImageUrls)
            {
                <img src="@url" alt="@Model.Name" class="h-40 w-full rounded-lg object-cover" />
            }
        </div>
    }

    <div class="mb-4 flex flex-wrap gap-2">
        @foreach (var cat in Model.Categories)
        {
            <span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-medium text-indigo-700">@cat</span>
        }
        @foreach (var tag in Model.Tags)
        {
            <span class="rounded-full bg-gray-100 px-3 py-1 text-xs text-gray-600">#@tag</span>
        }
    </div>

    <div class="mb-6 flex flex-wrap gap-6 text-sm text-gray-600">
        @if (Model.PrepTimeMinutes.HasValue) { <span>⏱️ Przygotowanie: @Model.PrepTimeMinutes min</span> }
        @if (Model.CookTimeMinutes.HasValue) { <span>🔥 Gotowanie: @Model.CookTimeMinutes min</span> }
        @if (Model.Servings.HasValue) { <span>🍽️ Porcje: @Model.Servings</span> }
        @if (Model.AverageRating.HasValue) { <span class="text-amber-500">★ @Model.AverageRating.Value.ToString("0.0") (@Model.ReviewCount)</span> }
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Description))
    {
        <p class="mb-6 text-gray-700">@Model.Description</p>
    }

    <div class="grid gap-6 md:grid-cols-3">
        <div class="md:col-span-1">
            <h2 class="mb-2 text-lg font-bold text-gray-800">Składniki</h2>
            <ul class="space-y-1 text-sm text-gray-700">
                @foreach (var ing in Model.Ingredients)
                {
                    <li class="flex justify-between border-b border-gray-100 py-1">
                        <span>@ing.IngredientName</span>
                        <span class="text-gray-500">@ing.Amount.ToString("0.##") @ing.UnitName</span>
                    </li>
                }
            </ul>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <form asp-controller="ShoppingList" asp-action="AddRecipe" method="post" class="mt-4 space-y-2 rounded-lg border border-indigo-100 bg-indigo-50 p-3">
                    <input type="hidden" name="recipeId" value="@Model.Id" />
                    <label class="block text-xs font-semibold text-gray-600">Dodaj składniki do listy zakupów</label>
                    @if (shoppingLists.Any())
                    {
                        <select name="listId" id="sl-select" class="w-full rounded-lg border border-gray-300 px-2 py-1.5 text-sm">
                            @foreach (var l in shoppingLists)
                            {
                                <option value="@l.Id">@l.Name</option>
                            }
                            <option value="0">— nowa lista —</option>
                        </select>
                        <input name="newListName" id="sl-newname" placeholder="Nazwa nowej listy" class="hidden w-full rounded-lg border border-gray-300 px-2 py-1.5 text-sm" />
                    }
                    else
                    {
                        <input name="newListName" placeholder="Nazwa nowej listy" class="w-full rounded-lg border border-gray-300 px-2 py-1.5 text-sm" />
                    }
                    <button type="submit" class="w-full rounded-lg bg-indigo-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-indigo-700">🛒 Dodaj do listy</button>
                </form>

                @if (shoppingLists.Any())
                {
                    <script>
                        (function () {
                            const select = document.getElementById('sl-select');
                            const nameInput = document.getElementById('sl-newname');
                            function toggle() {
                                nameInput.classList.toggle('hidden', select.value !== '0');
                            }
                            select.addEventListener('change', toggle);
                            toggle();
                        })();
                    </script>
                }
            }
        </div>

        <div class="md:col-span-2">
            <h2 class="mb-2 text-lg font-bold text-gray-800">Przygotowanie</h2>
            <ol class="space-y-3">
                @foreach (var step in Model.Steps)
                {
                    <li class="flex gap-3">
                        <span class="flex h-7 w-7 flex-none items-center justify-center rounded-full bg-indigo-600 text-sm font-semibold text-white">@step.Order</span>
                        <p class="pt-0.5 text-sm text-gray-700">@step.Content</p>
                    </li>
                }
            </ol>
        </div>
    </div>

    <div class="mt-8">
        <a asp-action="Index" class="text-sm text-indigo-600 hover:underline">← Wróć do listy</a>
    </div>
</div>
