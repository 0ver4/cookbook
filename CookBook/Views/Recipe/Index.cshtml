@model CookBook.Dtos.RecipeListViewModel
@{
    ViewData["Title"] = "Przepisy";
}

<partial name="_PageHeader" model="@("Przepisy")" />

<div class="mx-auto max-w-5xl px-4">

    <!-- Pasek wyszukiwania i filtrów -->
    <form method="get" class="mb-6 space-y-3">
        <div class="flex gap-2">
            <input type="text"
                   name="Search"
                   value="@Model.Query.Search"
                   placeholder="Szukaj przepisu..."
                   class="flex-1 rounded-lg border border-gray-300 px-4 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" />
            <button type="submit"
                    class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700">
                Szukaj
            </button>
        </div>

        <div class="flex flex-wrap gap-2">
            <!-- Kategoria -->
            <select name="CategoryId"
                    onchange="this.form.submit()"
                    class="rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none">
                <option value="">Wszystkie kategorie</option>
                @foreach (var c in Model.Categories)
                {
                    if (Model.Query.CategoryId == c.Id)
                    {
                        <option value="@c.Id" selected>@c.Name</option>
                    }
                    else
                    {
                        <option value="@c.Id">@c.Name</option>
                    }
                }
            </select>

            <!-- Trudność -->
            <select name="DifficultyId"
                    onchange="this.form.submit()"
                    class="rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none">
                <option value="">Każdy poziom</option>
                @foreach (var d in Model.Difficulties)
                {
                    if (Model.Query.DifficultyId == d.Id)
                    {
                        <option value="@d.Id" selected>@d.Name</option>
                    }
                    else
                    {
                        <option value="@d.Id">@d.Name</option>
                    }
                }
            </select>

            <!-- Sortowanie -->
            <select name="Sort"
                    onchange="this.form.submit()"
                    class="rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none">
                @if (Model.Query.Sort == "newest") { <option value="newest" selected>Najnowsze</option> } else { <option value="newest">Najnowsze</option> }
                @if (Model.Query.Sort == "rating") { <option value="rating" selected>Najwyżej oceniane</option> } else { <option value="rating">Najwyżej oceniane</option> }
                @if (Model.Query.Sort == "name")   { <option value="name" selected>Nazwa A–Z</option> }   else { <option value="name">Nazwa A–Z</option> }
            </select>

            <!-- Resetuj filtry (tylko gdy coś jest aktywne) -->
            @if (Model.Query.Search is not null || Model.Query.CategoryId.HasValue || Model.Query.DifficultyId.HasValue || Model.Query.Sort != "newest")
            {
                <a asp-action="Index" class="rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-500 hover:bg-gray-50">
                    ✕ Resetuj
                </a>
            }

            <!-- Przycisk dodaj -->
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-action="Create" class="ml-auto rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700">
                    + Dodaj przepis
                </a>
            }
        </div>
    </form>

    <!-- Licznik wyników -->
    <p class="mb-4 text-sm text-gray-500">
        @Model.TotalCount @(Model.TotalCount == 1 ? "przepis" : Model.TotalCount % 10 is >= 2 and <= 4 && Model.TotalCount % 100 is < 12 or > 14 ? "przepisy" : "przepisów")
        @if (Model.TotalPages > 1)
        {
            <span>• strona @Model.Page z @Model.TotalPages</span>
        }
    </p>

    @if (!Model.Recipes.Any())
    {
        <div class="rounded-lg border border-dashed border-gray-300 bg-white p-10 text-center text-gray-400">
            Brak przepisów spełniających podane kryteria.
        </div>
    }
    else
    {
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            @foreach (var r in Model.Recipes)
            {
                <a asp-action="Details" asp-route-id="@r.Id"
                   class="group block overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm transition hover:shadow-md">
                    <div class="h-40 w-full bg-gray-100">
                        @if (!string.IsNullOrEmpty(r.ImageUrl))
                        {
                            <img src="@r.ImageUrl" alt="@r.Name" class="h-full w-full object-cover" />
                        }
                        else
                        {
                            <div class="flex h-full items-center justify-center text-4xl text-gray-300">🍽️</div>
                        }
                    </div>
                    <div class="p-4">
                        <h3 class="font-semibold text-gray-800 group-hover:text-indigo-600">@r.Name</h3>
                        <p class="mt-1 text-xs text-gray-500">@r.AuthorName • @r.DifficultyName</p>

                        @if (r.Categories.Any())
                        {
                            <div class="mt-2 flex flex-wrap gap-1">
                                @foreach (var cat in r.Categories)
                                {
                                    <span class="rounded-full bg-indigo-50 px-2 py-0.5 text-xs text-indigo-600">@cat</span>
                                }
                            </div>
                        }

                        <div class="mt-2 flex items-center gap-1.5 text-sm">
                            @if (r.AverageRating.HasValue)
                            {
                                <span class="flex gap-0.5">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        string sc = r.AverageRating.Value >= i - 0.25 ? "text-amber-400" : (r.AverageRating.Value >= i - 0.75 ? "text-amber-300 opacity-60" : "text-gray-200");
                                        <span class="@sc text-base leading-none">★</span>
                                    }
                                </span>
                                <span class="font-semibold text-amber-600">@r.AverageRating.Value.ToString("0.0")</span>
                                <span class="text-gray-400 text-xs">(@r.ReviewCount)</span>
                            }
                            else
                            {
                                <span class="flex gap-0.5">
                                    @for (int i = 0; i < 5; i++) { <span class="text-gray-200 text-base leading-none">★</span> }
                                </span>
                                <span class="text-gray-400 text-xs">brak ocen</span>
                            }
                        </div>
                    </div>
                </a>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            // Buduje komplet parametrów query string dla danej strony, zachowując aktywne filtry/sortowanie.
            Dictionary<string, string> RouteFor(int page)
            {
                var data = new Dictionary<string, string> { ["Page"] = page.ToString(), ["Sort"] = Model.Query.Sort };
                if (!string.IsNullOrWhiteSpace(Model.Query.Search)) data["Search"] = Model.Query.Search;
                if (Model.Query.CategoryId.HasValue) data["CategoryId"] = Model.Query.CategoryId.Value.ToString();
                if (Model.Query.DifficultyId.HasValue) data["DifficultyId"] = Model.Query.DifficultyId.Value.ToString();
                return data;
            }

            int windowStart = Math.Max(1, Model.Page - 2);
            int windowEnd = Math.Min(Model.TotalPages, Model.Page + 2);

            <nav class="mt-8 flex items-center justify-center gap-1" aria-label="Stronicowanie">
                @if (Model.HasPrevious)
                {
                    <a asp-action="Index" asp-all-route-data="RouteFor(Model.Page - 1)"
                       class="rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-600 hover:bg-gray-50">‹ Poprzednia</a>
                }
                else
                {
                    <span class="rounded-lg border border-gray-200 px-3 py-2 text-sm text-gray-300">‹ Poprzednia</span>
                }

                @if (windowStart > 1)
                {
                    <a asp-action="Index" asp-all-route-data="RouteFor(1)" class="rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-600 hover:bg-gray-50">1</a>
                    if (windowStart > 2)
                    {
                        <span class="px-2 text-sm text-gray-400">…</span>
                    }
                }

                @for (int p = windowStart; p <= windowEnd; p++)
                {
                    if (p == Model.Page)
                    {
                        <span class="rounded-lg border border-indigo-600 bg-indigo-600 px-3 py-2 text-sm font-medium text-white">@p</span>
                    }
                    else
                    {
                        <a asp-action="Index" asp-all-route-data="RouteFor(p)" class="rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-600 hover:bg-gray-50">@p</a>
                    }
                }

                @if (windowEnd < Model.TotalPages)
                {
                    if (windowEnd < Model.TotalPages - 1)
                    {
                        <span class="px-2 text-sm text-gray-400">…</span>
                    }
                    <a asp-action="Index" asp-all-route-data="RouteFor(Model.TotalPages)" class="rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-600 hover:bg-gray-50">@Model.TotalPages</a>
                }

                @if (Model.HasNext)
                {
                    <a asp-action="Index" asp-all-route-data="RouteFor(Model.Page + 1)"
                       class="rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-600 hover:bg-gray-50">Następna ›</a>
                }
                else
                {
                    <span class="rounded-lg border border-gray-200 px-3 py-2 text-sm text-gray-300">Następna ›</span>
                }
            </nav>
        }
    }
</div>
