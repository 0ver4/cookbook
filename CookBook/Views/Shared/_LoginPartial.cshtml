@using Microsoft.AspNetCore.Identity
@using CookBook.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <div class="flex items-center gap-3">
        <a asp-area="Identity" asp-page="/Account/Manage/Index" title="Zarządzaj kontem"
           class="hidden text-sm text-gray-500 hover:text-gray-800 sm:inline">@User.Identity?.Name</a>
        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="rounded-lg bg-gray-100 px-3 py-1.5 text-sm font-medium text-gray-700 hover:bg-gray-200">Wyloguj</button>
        </form>
    </div>
}
else
{
    <div class="flex items-center gap-2">
        <a asp-area="Identity" asp-page="/Account/Login"
           class="rounded-lg px-3 py-1.5 text-sm font-medium text-gray-700 hover:bg-gray-100">Zaloguj się</a>
        <a asp-area="Identity" asp-page="/Account/Register"
           class="rounded-lg bg-indigo-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-indigo-700">Rejestracja</a>
    </div>
}
