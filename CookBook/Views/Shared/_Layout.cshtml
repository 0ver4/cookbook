@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();

    string Nav(string controller) => currentController == controller
        ? "bg-indigo-50 text-indigo-700 px-3 py-2 rounded-md text-sm font-medium transition-colors"
        : "text-gray-600 hover:bg-gray-100 hover:text-gray-900 px-3 py-2 rounded-md text-sm font-medium transition-colors";

    string NavMobile(string controller) => currentController == controller
        ? "block bg-indigo-50 text-indigo-700 px-3 py-2 rounded-md text-base font-medium"
        : "block text-gray-600 hover:bg-gray-100 hover:text-gray-900 px-3 py-2 rounded-md text-base font-medium transition-colors";

    string NavMod(string controller) => currentController == controller
        ? "bg-rose-50 text-rose-700 px-3 py-2 rounded-md text-sm font-medium transition-colors"
        : "text-rose-700 hover:bg-rose-50 hover:text-rose-900 px-3 py-2 rounded-md text-sm font-medium transition-colors";

    string NavModMobile(string controller) => currentController == controller
        ? "block bg-rose-50 text-rose-700 px-3 py-2 rounded-md text-base font-medium"
        : "block text-rose-700 hover:bg-rose-50 hover:text-rose-900 px-3 py-2 rounded-md text-base font-medium transition-colors";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CookBook</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="~/CookBook.styles.css" asp-append-version="true" />
    <style>
        /* Ukryj pusty box podsumowania walidacji, gdy nie ma błędów */
        .validation-summary-valid { display: none; }
    </style>
</head>
<body>
<header>
    <nav class="bg-white border-b shadow-sm mb-3">
        <div class="px-4">
            <div class="flex justify-between items-center py-2">
                <div class="hidden md:flex items-center space-x-4">
                    <a class="text-xl font-bold text-gray-800 hover:text-indigo-600 transition-colors" asp-area="" asp-controller="Home" asp-action="Index">🍳 CookBook</a>

                    <a class="@Nav("Home")" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                    <a class="@Nav("Recipe")" asp-area="" asp-controller="Recipe" asp-action="Index">Przepisy</a>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a class="@Nav("Collection")" asp-area="" asp-controller="Collection" asp-action="Index">Kolekcje</a>
                        <a class="@Nav("ShoppingList")" asp-area="" asp-controller="ShoppingList" asp-action="Index">Lista zakupów</a>
                        <a class="@Nav("MealPlan")" asp-area="" asp-controller="MealPlan" asp-action="Index">Plan posiłków</a>
                    }
                    @if (User.IsInRole("Moderator"))
                    {
                        <a class="@NavMod("Category")" asp-area="" asp-controller="Category" asp-action="Index">🛡️ Słowniki</a>
                        <a class="@NavMod("Report")" asp-area="" asp-controller="Report" asp-action="Index">🚩 Zgłoszenia @await Component.InvokeAsync("ReportBadge")</a>
                    }
                    <a class="@Nav("Profile")" asp-area="" asp-controller="Profile" asp-action="Index">👤 Moje Konto</a>
                </div>
                <div class="hidden md:flex items-center gap-4">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @await Component.InvokeAsync("NotificationBadge")
                    }
                    <partial name="_LoginPartial" />
                </div>

                <div class="md:hidden flex items-center">
                    <button id="mobile-menu-button" class="inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:text-gray-500 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-indigo-500">
                        <span class="sr-only">Open main menu</span>
                        <svg id="menu-icon-open" class="h-6 w-6 block" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                        </svg>
                        <svg id="menu-icon-close" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        <div id="mobile-menu" class="md:hidden hidden">
            <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
                <a class="@NavMobile("Home")" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                <a class="@NavMobile("Recipe")" asp-area="" asp-controller="Recipe" asp-action="Index">Przepisy</a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a class="@NavMobile("Collection")" asp-area="" asp-controller="Collection" asp-action="Index">Kolekcje</a>
                    <a class="@NavMobile("ShoppingList")" asp-area="" asp-controller="ShoppingList" asp-action="Index">Lista zakupów</a>
                    <a class="@NavMobile("MealPlan")" asp-area="" asp-controller="MealPlan" asp-action="Index">Plan posiłków</a>
                }
                @if (User.IsInRole("Moderator"))
                {
                    <a class="@NavModMobile("Category")" asp-area="" asp-controller="Category" asp-action="Index">🛡️ Słowniki</a>
                    <a class="@NavModMobile("Report")" asp-area="" asp-controller="Report" asp-action="Index">🚩 Zgłoszenia @await Component.InvokeAsync("ReportBadge")</a>
                }
                <a class="@NavMobile("Profile")" asp-area="" asp-controller="Profile" asp-action="Index">👤 Moje Konto</a>
            </div>
            <div class="pt-4 pb-3 border-t border-gray-200">
                <div class="px-2">
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </div>
    </nav>
</header>

<partial name="_Alert" />

<main role="main" class="min-h-[70vh] pb-3">
    @RenderBody()
</main>

<footer class="mt-12 border-t border-gray-200 py-6">
    <div class="mx-auto max-w-5xl px-4 text-sm text-gray-400">
        &copy; 2026 CookBook · <a class="hover:text-gray-600" asp-area="" asp-controller="Home" asp-action="Privacy">Prywatność</a>
    </div>
</footer>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const menuButton = document.getElementById('mobile-menu-button');
        const mobileMenu = document.getElementById('mobile-menu');
        const menuIconOpen = document.getElementById('menu-icon-open');
        const menuIconClose = document.getElementById('menu-icon-close');

        menuButton.addEventListener('click', function () {
            mobileMenu.classList.toggle('hidden');
            menuIconOpen.classList.toggle('block');
            menuIconOpen.classList.toggle('hidden');
            menuIconClose.classList.toggle('hidden');
            menuIconClose.classList.toggle('block');
        });
    });
</script>
</body>
</html>
