@* Naglowek strony. Uzycie: <partial name="_PageHeader" model="@("Tytuł")" />
   Opcjonalny podtytul przez ViewData["Subtitle"].
   Szerokosc dopasuj do tresci przez ViewData["HeaderWidth"] (domyslnie max-w-5xl). *@
@model string
@{
    var headerWidth = ViewData["HeaderWidth"] as string ?? "max-w-5xl";
}

<div class="mx-auto @headerWidth px-4 pt-6 pb-2">
    <h1 class="text-2xl font-bold text-gray-800">@Model</h1>
    @if (ViewData["Subtitle"] != null)
    {
        <p class="text-sm text-gray-500 mt-1">@ViewData["Subtitle"]</p>
    }
</div>
