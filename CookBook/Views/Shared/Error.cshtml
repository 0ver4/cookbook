@model ErrorViewModel
@{
    ViewData["Title"] = "Błąd";
}

<div class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="mb-2 text-2xl font-bold text-red-600">Wystąpił błąd.</h1>
    <p class="mb-4 text-gray-600">Podczas przetwarzania żądania wystąpił błąd.</p>

    @if (Model.ShowRequestId)
    {
        <p class="text-sm text-gray-500">
            <strong>Request ID:</strong> <code class="rounded bg-gray-100 px-1">@Model.RequestId</code>
        </p>
    }

    <a asp-controller="Home" asp-action="Index" class="mt-6 inline-block text-sm text-indigo-600 hover:underline">← Wróć na stronę główną</a>
</div>
