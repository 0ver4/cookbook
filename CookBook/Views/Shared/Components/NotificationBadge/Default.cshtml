@model int
<a asp-controller="Notification" asp-action="Index"
   class="relative text-gray-700 hover:text-gray-900 px-3 py-2 rounded-md text-sm font-medium">
    🔔
    @if (Model > 0)
    {
        <span class="absolute -top-1 -right-1 flex h-4 w-4 items-center justify-center rounded-full bg-red-500 text-xs font-bold text-white">
            @(Model > 9 ? "9+" : Model.ToString())
        </span>
    }
</a>
