@using CookBook.Models
@using CookBook.ViewModels
@model CookBook.ViewModels.MealPlanWeekViewModel
@{
    ViewData["Title"] = "Plan posiłków";
    string[] dayNames = { "Poniedziałek", "Wtorek", "Środa", "Czwartek", "Piątek", "Sobota", "Niedziela" };
    var weekEnd = Model.WeekStart.AddDays(6);
}

<partial name="_PageHeader" model="@("Plan posiłków")" />

<div class="mx-auto max-w-6xl px-4">

    @* Nawigacja tygodni *@
    <div class="mb-4 flex items-center justify-between">
        <a asp-action="Index" asp-route-weekStart="@Model.PreviousWeek.ToString("yyyy-MM-dd")"
           class="rounded-lg border border-gray-300 px-3 py-1.5 text-sm text-gray-700 hover:bg-gray-50">← Poprzedni</a>
        <span class="text-sm font-semibold text-gray-700">
            @Model.WeekStart.ToString("dd.MM") – @weekEnd.ToString("dd.MM.yyyy")
        </span>
        <a asp-action="Index" asp-route-weekStart="@Model.NextWeek.ToString("yyyy-MM-dd")"
           class="rounded-lg border border-gray-300 px-3 py-1.5 text-sm text-gray-700 hover:bg-gray-50">Następny →</a>
    </div>

    @* Pasek dodawania *@
    @if (!Model.Recipes.Any())
    {
        <div class="mb-4 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
            Brak przepisów do zaplanowania. Najpierw <a asp-controller="Recipe" asp-action="Create" class="underline">dodaj przepis</a>.
        </div>
    }
    else
    {
        <form asp-action="AddItem" method="post" class="mb-6 flex flex-wrap items-end gap-2 rounded-lg border border-gray-200 bg-white p-4 shadow-sm">
            <div>
                <label class="mb-1 block text-xs font-semibold text-gray-600">Dzień</label>
                <select name="date" class="rounded-lg border border-gray-300 px-2 py-1.5 text-sm">
                    @for (var i = 0; i < 7; i++)
                    {
                        var d = Model.WeekStart.AddDays(i);
                        <option value="@d.ToString("yyyy-MM-dd")">@dayNames[i] (@d.ToString("dd.MM"))</option>
                    }
                </select>
            </div>
            <div>
                <label class="mb-1 block text-xs font-semibold text-gray-600">Posiłek</label>
                <select name="mealType" class="rounded-lg border border-gray-300 px-2 py-1.5 text-sm">
                    @foreach (var slot in MealTypeInfo.Ordered)
                    {
                        <option value="@((int)slot)">@MealTypeInfo.Label(slot)</option>
                    }
                </select>
            </div>
            <div class="flex-1 min-w-48">
                <label class="mb-1 block text-xs font-semibold text-gray-600">Przepis</label>
                <select name="recipeId" class="w-full rounded-lg border border-gray-300 px-2 py-1.5 text-sm">
                    @foreach (var r in Model.Recipes)
                    {
                        <option value="@r.Id">@r.Name</option>
                    }
                </select>
            </div>
            <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700">Dodaj</button>
        </form>
    }

    @* Siatka tygodnia *@
    <div class="overflow-x-auto">
        <table class="min-w-full border-separate border-spacing-1">
            <thead>
            <tr>
                <th class="w-24"></th>
                @for (var i = 0; i < 7; i++)
                {
                    var d = Model.Days[i].Date;
                    var isToday = d == DateTime.Today;
                    <th class="rounded-lg @(isToday ? "bg-indigo-600 text-white" : "bg-gray-100 text-gray-600") px-2 py-2 text-center text-xs font-semibold">
                        <div>@dayNames[i].Substring(0, 3)</div>
                        <div class="text-[11px] font-normal">@d.ToString("dd.MM")</div>
                    </th>
                }
            </tr>
            </thead>
            <tbody>
            @foreach (var slot in MealTypeInfo.Ordered)
            {
                <tr>
                    <td class="rounded-lg bg-gray-50 px-2 py-2 text-right text-xs font-semibold text-gray-500 align-top">@MealTypeInfo.Label(slot)</td>
                    @foreach (var day in Model.Days)
                    {
                        <td class="min-w-32 rounded-lg border border-gray-100 bg-white p-1.5 align-top">
                            @foreach (var entry in day.Meals[slot])
                            {
                                <div class="mb-1 flex items-start justify-between gap-1 rounded bg-indigo-50 px-2 py-1 text-xs text-indigo-800">
                                    <a asp-controller="Recipe" asp-action="Details" asp-route-id="@entry.RecipeId" class="hover:underline">@entry.RecipeName</a>
                                    <form asp-action="RemoveItem" method="post" class="flex-none">
                                        <input type="hidden" name="id" value="@entry.ItemId" />
                                        <input type="hidden" name="weekStart" value="@Model.WeekStart.ToString("yyyy-MM-dd")" />
                                        <button type="submit" class="text-indigo-400 hover:text-red-600" title="Usuń">✕</button>
                                    </form>
                                </div>
                            }
                        </td>
                    }
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
