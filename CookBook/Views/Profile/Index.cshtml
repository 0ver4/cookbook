@model CookBook.Models.ApplicationUser
@{
    ViewData["Title"] = "Moje Konto";

    string dataRejestracji = (Model != null && Model.AccountCreated.Year > 2000)
        ? Model.AccountCreated.ToLocalTime().ToString("dd.MM.yyyy")
        : DateTime.Now.ToString("dd.MM.yyyy");

    var displayName = string.IsNullOrEmpty(Model?.FirstName)
        ? Model?.Email?.Split('@')[0]
        : $"{Model.FirstName} {Model.LastName}";
    var role = ViewBag.UserRole as string;
    var isModerator = !string.IsNullOrEmpty(role) && role != "Brak roli";
}

<div class="mx-auto max-w-5xl px-4 py-8">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-800">Witaj w swojej kuchni!</h1>
        <p class="text-sm text-gray-500">Zarządzaj swoimi przepisami, ulubionymi smakami i ustawieniami konta.</p>
    </div>

    <div class="grid gap-6 lg:grid-cols-3">
        <!-- Karta profilu -->
        <div class="rounded-xl border border-gray-200 bg-white p-6 text-center shadow-sm">
            <div class="mx-auto mb-3 flex h-24 w-24 items-center justify-center rounded-full bg-gradient-to-br from-rose-300 to-pink-200 text-3xl font-bold text-white">
                @Model?.Email?[0].ToString().ToUpper()
            </div>
            <h2 class="text-lg font-bold text-gray-800">@displayName</h2>
            <p class="mb-3 text-sm text-gray-500">@Model?.Email</p>

            @if (isModerator)
            {
                <span class="inline-flex items-center gap-1 rounded-full bg-rose-100 px-3 py-1 text-xs font-medium text-rose-700">🛡️ @role</span>
            }
            else
            {
                <span class="inline-flex items-center gap-1 rounded-full bg-green-100 px-3 py-1 text-xs font-medium text-green-700">👤 Kucharz Amator</span>
            }

            <div class="mt-4 space-y-1 border-t border-gray-100 pt-4 text-sm">
                <div class="flex justify-between">
                    <span class="text-gray-500">Dołączył:</span>
                    <span class="font-medium text-gray-700">@dataRejestracji</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-gray-500">ID konta:</span>
                    <span class="rounded bg-gray-100 px-2 text-gray-600">#@Model?.Id</span>
                </div>
            </div>

            <div class="mt-4 space-y-2">
                <a asp-action="Edit" class="block w-full rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700">Edytuj dane profilu</a>
                <a asp-controller="Home" asp-action="Index" class="block w-full rounded-lg border border-gray-300 px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">Powrót do menu</a>
            </div>
        </div>

        <!-- Statystyki + aktywność -->
        <div class="lg:col-span-2">
            <div class="mb-4 grid grid-cols-3 gap-3">
                <div class="rounded-xl border border-gray-200 bg-white p-4 text-center shadow-sm">
                    <div class="text-2xl font-bold text-amber-500">0</div>
                    <div class="text-xs font-medium text-gray-500">📖 Moje przepisy</div>
                </div>
                <div class="rounded-xl border border-gray-200 bg-white p-4 text-center shadow-sm">
                    <div class="text-2xl font-bold text-rose-500">0</div>
                    <div class="text-xs font-medium text-gray-500">❤️ Ulubione</div>
                </div>
                <div class="rounded-xl border border-gray-200 bg-white p-4 text-center shadow-sm">
                    <div class="text-2xl font-bold text-sky-500">0</div>
                    <div class="text-xs font-medium text-gray-500">💬 Komentarze</div>
                </div>
            </div>

            <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
                <h3 class="mb-4 font-bold text-gray-800">⚡ Ostatnia aktywność</h3>
                <div class="flex flex-col items-center justify-center py-10 text-center text-gray-400">
                    <div class="mb-2 text-3xl opacity-40">🍴</div>
                    <p class="text-sm font-semibold">Nie dodałeś jeszcze żadnych przepisów ani opinii.</p>
                    <p class="text-xs">Twoja kulinarna przygoda zaczyna się tutaj!</p>
                </div>
            </div>
        </div>
    </div>
</div>
