@model CookBook.Models.ApplicationUser
@{
    ViewData["Title"] = "Edycja Profilu";
}

<partial name="_PageHeader" model="@("Edytuj swoje dane")" />

<div class="mx-auto max-w-lg px-4">
    <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
        <p class="mb-4 text-sm text-gray-500">Uzupełnij imię i nazwisko, aby spersonalizować swój profil kulinarny.</p>

        <form asp-action="Edit" method="post" class="space-y-4">
            <div asp-validation-summary="ModelOnly" class="text-sm text-red-600"></div>

            <div>
                <label class="mb-1 block text-sm font-semibold text-gray-700">Imię</label>
                <input type="text" name="firstName" value="@Model.FirstName" placeholder="Wpisz swoje imię"
                       class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" />
            </div>

            <div>
                <label class="mb-1 block text-sm font-semibold text-gray-700">Nazwisko</label>
                <input type="text" name="lastName" value="@Model.LastName" placeholder="Wpisz swoje nazwisko"
                       class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" />
            </div>

            <div class="flex justify-end gap-2">
                <a asp-action="Index" class="rounded-lg border border-gray-300 px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">Anuluj</a>
                <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700">Zapisz zmiany</button>
            </div>
        </form>
    </div>
</div>
