@model CookBook.Models.ApplicationUser

@{
    ViewData["Title"] = "Edycja Profilu";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-3 bg-white p-4">
                <div class="card-body">
                    <h3 class="fw-bold text-dark mb-3">✏️ Edytuj swoje dane</h3>
                    <p class="text-muted small">Uzupełnij swoje imię i nazwisko, aby spersonalizować swój profil kulinarny.</p>
                    <hr />

                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-3">
                            <label class="form-label small fw-semibold text-secondary">Imię</label>
                            <input type="text" name="firstName" value="@Model.FirstName" class="form-control rounded-pill shadow-sm" placeholder="Wpisz swoje imię" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-semibold text-secondary">Nazwisko</label>
                            <input type="text" name="lastName" value="@Model.LastName" class="form-control rounded-pill shadow-sm" placeholder="Wpisz swoje nazwisko" />
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                            <a asp-action="Index" class="btn btn-sm btn-outline-secondary rounded-pill px-4">Anuluj</a>
                            <button type="submit" class="btn btn-sm btn-primary rounded-pill px-4 shadow">Zapisz zmiany</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>