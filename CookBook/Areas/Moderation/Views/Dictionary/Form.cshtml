@model CookBook.Dtos.LookupFormVm
@{
    var d = Model.Descriptor;
    var isNew = Model.Id == 0;
    ViewData["Title"] = isNew ? $"Nowy wpis — {d.Plural}" : $"Edycja — {d.Plural}";
}

<div class="mx-auto max-w-lg px-4 py-6">
    <h2 class="mb-3 text-lg font-bold text-gray-800">@ViewData["Title"]</h2>
    <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
        <form asp-action="@(isNew ? "Create" : "Edit")" asp-route-slug="@d.Slug" asp-route-id="@(isNew ? null : (int?)Model.Id)" method="post">
            <div asp-validation-summary="ModelOnly" class="mb-3 text-sm text-red-600"></div>

            <div class="mb-4">
                <label for="name" class="mb-1 block text-sm font-semibold text-gray-700">Nazwa</label>
                <input id="name" name="name" value="@Model.Name" maxlength="50" required
                       class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" />
                <span asp-validation-for="Name" class="mt-1 block text-sm text-red-600"></span>
            </div>

            <div class="flex justify-end gap-2">
                <a asp-action="Index" asp-route-slug="@d.Slug" class="rounded-lg border border-gray-300 px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">Anuluj</a>
                <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700">Zapisz</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
