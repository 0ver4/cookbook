@model CookBook.Dtos.LookupFormVm
@{
    var d = Model.Descriptor;
    ViewData["Title"] = $"Usuń — {d.Plural}";
}

<div class="mx-auto max-w-lg px-4 py-6">
    <h2 class="mb-3 text-lg font-bold text-gray-800">@ViewData["Title"]</h2>
    <div class="rounded-lg border border-red-200 bg-white p-6 shadow-sm">
        <p class="mb-4 text-sm text-gray-700">
            Czy na pewno chcesz usunąć pozycję
            <span class="font-semibold text-gray-900">„@Model.Name”</span>?
        </p>

        <form asp-action="DeleteConfirmed" asp-route-slug="@d.Slug" asp-route-id="@Model.Id" method="post">
            <div class="flex justify-end gap-2">
                <a asp-action="Index" asp-route-slug="@d.Slug" class="rounded-lg border border-gray-300 px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">Anuluj</a>
                <button type="submit" class="rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700">Usuń</button>
            </div>
        </form>
    </div>
</div>
