@model CookBook.Dtos.UpdateCategoryDto
@{
    ViewData["Title"] = "Edycja kategorii";
}

<div class="mx-auto max-w-lg px-4 py-6">
    <h2 class="mb-3 text-lg font-bold text-gray-800">Edycja kategorii</h2>
    <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="mb-3 text-sm text-red-600"></div>
            <input type="hidden" asp-for="Id" />

            <div class="mb-4">
                <label asp-for="Name" class="mb-1 block text-sm font-semibold text-gray-700"></label>
                <input asp-for="Name" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" />
                <span asp-validation-for="Name" class="mt-1 block text-sm text-red-600"></span>
            </div>

            <div class="flex justify-end gap-2">
                <a asp-action="Index" class="rounded-lg border border-gray-300 px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">Anuluj</a>
                <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700">Zapisz zmiany</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
