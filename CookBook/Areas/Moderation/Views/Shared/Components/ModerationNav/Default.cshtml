@model CookBook.Areas.Moderation.ModerationNavVm
@{
    var current = ViewContext.RouteData.Values["controller"]?.ToString();

    string Tab(string controller) => current == controller
        ? "border-indigo-600 text-indigo-700"
        : "border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700";
}

<nav class="mt-3 flex gap-6 border-b border-gray-200">
    <a asp-area="Moderation" asp-controller="Reports" asp-action="Index"
       class="@Tab("Reports") -mb-px flex items-center gap-1.5 border-b-2 px-1 pb-2.5 text-sm font-medium">
        <span>🚩 Zgłoszenia</span>
        @if (Model.PendingReports > 0)
        {
            <span class="inline-flex h-4 min-w-[1rem] items-center justify-center rounded-full bg-red-500 px-1 text-xs font-bold text-white">@Model.PendingReports</span>
        }
    </a>
    <a asp-area="Moderation" asp-controller="Categories" asp-action="Index"
       class="@Tab("Categories") -mb-px flex items-center gap-1.5 border-b-2 px-1 pb-2.5 text-sm font-medium">
        <span>🏷️ Kategorie</span>
        <span class="inline-flex h-4 min-w-[1rem] items-center justify-center rounded-full bg-gray-100 px-1 text-xs font-medium text-gray-600">@Model.CategoryCount</span>
    </a>
</nav>
